# ═══════════════════════════════════════════════════════════════════════
#  Audio Server — 所有可配置项
# ═══════════════════════════════════════════════════════════════════════
# 复制此文件为 .env 后按需修改：
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── 功能开关 ──────────────────────────────────────────────────────────

# ASR_ENABLED: 启用语音识别
#   可选值: true | false
#   默认值: true
#   设为 false 可只运行 TTS，不加载 ASR 模型
ASR_ENABLED=true

# TTS_ENABLED: 启用语音合成
#   可选值: true | false
#   默认值: false
#   设为 true 时启动时自动加载 TTS 模型
TTS_ENABLED=false


# ── ASR: sherpa-onnx 通用选项 ─────────────────────────────────────────

# SHERPA_ONNX_MODEL_TYPE: ASR 模型类型
#   可选值: sense_voice | funasr_nano | funasr_mlt_nano | qwen3_asr | whisper | moonshine_v2
#   默认值: 根据模型名自动检测
#   说明: 设置后将强制使用此模型类型
SHERPA_ONNX_MODEL_TYPE=

# SHERPA_ONNX_MODEL: ASR 模型名称
#   可选值:
#     - sherpa-onnx-sense-voice-zh-en-ja-ko-yue-int8-2025-09-09  (中/英/日/韩/粤, ~228MB)
#     - sherpa-onnx-funasr-nano-int8-2025-12-30                  (中/英/日, ~150MB)
#     - sherpa-onnx-funasr-mlt-nano-int8-2025-12-30              (多语言版 FunASR Nano, ~150MB)
#     - sherpa-onnx-qwen3-asr-0.6B-int8-2026-03-25              (Qwen3 0.6B, 多语言, ~600MB)
#     - sherpa-onnx-whisper-{size}                                (Whisper 系列)
#     - sherpa-onnx-moonshine-base-zh-quantized-2026-02-27       (Moonshine V2 中文)
#     - sherpa-onnx-moonshine-base-en-quantized-2026-02-27       (Moonshine V2 英文)
#     - sherpa-onnx-moonshine-base-es-quantized-2026-02-27       (Moonshine V2 西班牙语)
#   默认值: sherpa-onnx-qwen3-asr-0.6B-int8-2026-03-25
SHERPA_ONNX_MODEL=sherpa-onnx-qwen3-asr-0.6B-int8-2026-03-25

# SHERPA_ONNX_MODEL_DIR: 本地 ASR 模型目录
#   可选值: 任意路径
#   默认值: ""（空=自动从 GitHub 下载到缓存目录）
#   说明: 设置后跳过自动下载，直接使用指定目录
SHERPA_ONNX_MODEL_DIR=

# SHERPA_ONNX_NUM_THREADS: ASR 推理线程数
#   可选值: 正整数
#   默认值: 2
#   说明: 线程数越高推理越快，但占用更多 CPU
SHERPA_ONNX_NUM_THREADS=2

# SHERPA_ONNX_LANGUAGE: ASR 识别语言
#   可选值: ""（自动）| zh | en | ja | ko | yue 等
#   默认值: ""（自动检测）
#   说明: 指定语种可提升准确率
SHERPA_ONNX_LANGUAGE=

# SHERPA_ONNX_ITN: 启用逆文本正则化（数字/日期格式化）
#   可选值: true | false
#   默认值: true
#   说明: 将 "二零二五年" 转为 "2025年" 等
SHERPA_ONNX_ITN=true


# ── ASR: Whisper 专用选项 ────────────────────────────────────────────
# 仅当 SHERPA_ONNX_MODEL_TYPE=whisper 时生效

# SHERPA_ONNX_WHISPER_LANGUAGE: Whisper 识别语言
#   可选值: zh | en | ja 等
#   默认值: zh
SHERPA_ONNX_WHISPER_LANGUAGE=zh

# SHERPA_ONNX_WHISPER_TASK: Whisper 任务类型
#   可选值: transcribe（转写）| translate（翻译为英文）
#   默认值: transcribe
SHERPA_ONNX_WHISPER_TASK=transcribe

# SHERPA_ONNX_WHISPER_TAIL_PADDINGS: Whisper 尾部填充
#   可选值: -1（自动）| 0 | 正整数
#   默认值: -1
#   说明: 控制音频末尾填充的静音帧数
SHERPA_ONNX_WHISPER_TAIL_PADDINGS=-1


# ── ASR: VAD（语音活动检测）───────────────────────────────────────────

# VAD_FRAME_MS: VAD 帧长度（毫秒）
#   可选值: 10 | 20 | 30
#   默认值: 30
#   说明: webrtcvad 只支持 10/20/30ms
VAD_FRAME_MS=30

# VAD_MODE: VAD 灵敏度
#   可选值: 0（最不敏感）| 1 | 2 | 3（最敏感）
#   默认值: 0
#   说明: 值越高越容易检测到语音（但也容易误判噪音为语音）
VAD_MODE=0

# VAD_THRESHOLD: VAD 阈值（0.0-1.0）
#   可选值: 0.0 ~ 1.0
#   默认值: 0.0
#   说明: 与 VAD_MODE 互斥，当 VAD_MODE=0 且此值 > 0 时自动映射为 mode 0-3
VAD_THRESHOLD=0.0

# SILENCE_DURATION_MS: 静音判定时长（毫秒）
#   可选值: 正整数（建议 300-2000）
#   默认值: 600
#   说明: 持续静音超过此时间触发最终识别结果
SILENCE_DURATION_MS=600


# ── 音频 ──────────────────────────────────────────────────────────────

# SAMPLE_RATE: 音频采样率
#   可选值: 8000 | 16000 | 44100 | 48000
#   默认值: 16000
#   说明: ASR 通常使用 16kHz
SAMPLE_RATE=16000


# ── TTS（语音合成）────────────────────────────────────────────────────

# TTS_MODEL: TTS 模型名称
#   可选值: matcha-icefall-zh-en（中英混合）
#   默认值: matcha-icefall-zh-en
#   说明: 使用 Matcha-TTS 架构，支持中英文混合合成
TTS_MODEL=matcha-icefall-zh-en

# TTS_MODEL_DIR: 本地 TTS 模型目录
#   可选值: 任意路径
#   默认值: ""（空=自动从 GitHub 下载到缓存目录）
TTS_MODEL_DIR=

# TTS_VOCODER: 声码器模型
#   可选值: vocos-16khz-univ
#   默认值: vocos-16khz-univ
#   说明: 输出 16kHz 音频
TTS_VOCODER=vocos-16khz-univ

# TTS_NUM_THREADS: TTS 推理线程数
#   可选值: 正整数
#   默认值: 4
TTS_NUM_THREADS=4

# TTS_PROVIDER: TTS 推理后端
#   可选值: cpu | cuda
#   默认值: cpu
#   说明: x86 平台可用 cuda 启用 GPU 加速
TTS_PROVIDER=cpu

# TTS_SID: 说话人 ID
#   可选值: 0（当前模型仅支持 0）
#   默认值: 0
TTS_SID=0

# TTS_SPEED: 语速
#   可选值: 0.5 ~ 2.0
#   默认值: 1.0
TTS_SPEED=1.0

# TTS_MAX_NUM_SENTENCES: 最大句子数
#   可选值: 正整数
#   默认值: 1
#   说明: 输入文本按标点分句，超过此数时截断
TTS_MAX_NUM_SENTENCES=1


# ── 服务器 ────────────────────────────────────────────────────────────

# HOST: 监听地址
#   可选值: 任意 IP 地址或主机名
#   默认值: 0.0.0.0
#   说明: 0.0.0.0 监听所有网卡，127.0.0.1 仅本地
HOST=0.0.0.0

# PORT: 监听端口
#   可选值: 1024 ~ 65535
#   默认值: 8000
PORT=8000

# MAX_CONNECTIONS: 最大并发 WebSocket 连接数
#   可选值: 正整数
#   默认值: 4
#   说明: 同时处理的 ASR 会话数，超过后新连接被拒绝
MAX_CONNECTIONS=4


# ── 缓存 ──────────────────────────────────────────────────────────────

# MODEL_CACHE_DIR: 模型缓存目录
#   可选值: 任意路径
#   默认值: ~/.cache/audio-server
#   说明: ASR 和 TTS 模型自动下载到此目录
MODEL_CACHE_DIR=
