# ═══════════════════════════════════════════════════════════════════════
#  Audio Server — 所有可配置项
# ═══════════════════════════════════════════════════════════════════════
# 复制此文件为 .env 后按需修改：
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── 功能开关 ──────────────────────────────────────────────────────────

# ASR_ENABLED: 启用语音识别
#   可选值: true | false
#   默认值: true
#   设为 false 可只运行 TTS，不加载 ASR 模型
ASR_ENABLED=false

# TTS_ENABLED: 启用语音合成
#   可选值: true | false
#   默认值: false
#   设为 true 时启动时自动加载 TTS 模型
TTS_ENABLED=true

# ── 音频 ──────────────────────────────────────────────────────────────

# SAMPLE_RATE: 音频采样率
#   可选值: 8000 | 16000 | 44100 | 48000
#   默认值: 16000
#   说明: ASR 通常使用 16kHz
SAMPLE_RATE=16000


# ── TTS（语音合成）────────────────────────────────────────────────────

# TTS_MODEL: TTS 模型名称
#   可选值:
#     - matcha-icefall-zh-en（中英混合，sherpa-onnx 后端）
#     - Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice（0.6B，qwen-tts 后端）
#     - Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice（1.7B，qwen-tts 后端，支持 instruct）
#   默认值: matcha-icefall-zh-en
#   说明: 以 Qwen/Qwen3-TTS-12Hz- 开头时自动切换为 Qwen3-TTS 后端
TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice

# TTS_MODEL_DIR: 本地 TTS 模型目录
#   可选值: 任意路径
#   默认值: ""（空=自动从 GitHub 下载到缓存目录）
#   说明: 仅 sherpa-onnx 后端有效
TTS_MODEL_DIR=

# TTS_VOCODER: 声码器模型
#   可选值: vocos-16khz-univ
#   默认值: vocos-16khz-univ
#   说明: 输出 16kHz 音频，仅 sherpa-onnx 后端有效
TTS_VOCODER=vocos-16khz-univ

# TTS_NUM_THREADS: TTS 推理线程数
#   可选值: 正整数
#   默认值: 4
#   说明: 仅 sherpa-onnx 后端有效
TTS_NUM_THREADS=2

# TTS_PROVIDER: TTS 推理后端
#   可选值: cpu | cuda
#   默认值: cpu
#   说明: x86 平台可用 cuda 启用 GPU 加速，仅 sherpa-onnx 后端有效
TTS_PROVIDER=cuda

# TTS_SID: 说话人 ID
#   可选值: 0（当前模型仅支持 0）
#   默认值: 0
#   说明: 仅 sherpa-onnx 后端有效
TTS_SID=0

# TTS_SPEED: 语速
#   可选值: 0.5 ~ 2.0
#   默认值: 1.0
#   说明: 仅 sherpa-onnx 后端有效
TTS_SPEED=1.0

# TTS_MAX_NUM_SENTENCES: 最大句子数
#   可选值: 正整数
#   默认值: 1
#   说明: 输入文本按标点分句，超过此数时截断，仅 sherpa-onnx 后端有效
TTS_MAX_NUM_SENTENCES=1


# ── TTS: Qwen3-TTS 选项（qwen-tts 后端）─────────────────────────────

# TTS_QWEN3_MODEL: Qwen3-TTS 模型 ID
#   可选值:
#     - Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice（~600MB）
#     - Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice（~3GB，支持 instruct 指令控制）
#   默认值: Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
#   说明: 仅在 TTS_MODEL 为 Qwen3 模型时生效
TTS_QWEN3_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice

# TTS_QWEN3_DEVICE: 推理设备
#   可选值: cuda:0 | cpu | cuda:1 等
#   默认值: cuda:0
#   说明: Qwen3-TTS 需要 GPU（0.6B 至少 4GB VRAM，1.7B 至少 8GB VRAM）
TTS_QWEN3_DEVICE=cuda:0

# TTS_QWEN3_DTYPE: 数据类型
#   可选值: float16 | bfloat16 | float32
#   默认值: bfloat16
#   说明: bfloat16 是推荐的平衡选择，float16 更快但精度略低
TTS_QWEN3_DTYPE=bfloat16

# TTS_QWEN3_SPEAKER: 默认发音人
#   可选值: Vivian | Serena | Uncle_Fu | Dylan | Eric | Ryan | Aiden | Ono_Anna | Sohee
#   默认值: Vivian
#   说明: 各发音人有不同语言和风格，详见 README
TTS_QWEN3_SPEAKER=Vivian

# TTS_QWEN3_LANGUAGE: 默认语种
#   可选值: Auto（自动检测）| Chinese | English | Japanese | Korean 等
#   默认值: Auto
#   说明: 明确指定语种可提升合成质量
TTS_QWEN3_LANGUAGE=Auto


# ── 服务器 ────────────────────────────────────────────────────────────

# HOST: 监听地址
#   可选值: 任意 IP 地址或主机名
#   默认值: 0.0.0.0
#   说明: 0.0.0.0 监听所有网卡，127.0.0.1 仅本地
HOST=0.0.0.0

# PORT: 监听端口
#   可选值: 1024 ~ 65535
#   默认值: 8000
PORT=8000

# MAX_CONNECTIONS: 最大并发 WebSocket 连接数
#   可选值: 正整数
#   默认值: 4
#   说明: 同时处理的 ASR 会话数，超过后新连接被拒绝
MAX_CONNECTIONS=18


# ── 缓存 ──────────────────────────────────────────────────────────────

# MODEL_CACHE_DIR: 模型缓存目录
#   可选值: 任意路径
#   默认值: ~/.cache/audio-server
#   说明: ASR 和 TTS 模型自动下载到此目录
MODEL_CACHE_DIR=/mnt/efs/fs1/audio_server_cache/
